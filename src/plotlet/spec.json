{
  "version": "0.1.0",
  "size": {
    "width": 600,
    "height": 400,
    "margin": {"top": 30, "right": 18, "bottom": 48, "left": 58},
    "margin_floor": {"top": 24, "right": 4, "bottom": 20, "left": 20}
  },
  "font": {
    "family": "DejaVu Sans, Bitstream Vera Sans, Verdana, Arial, sans-serif",
    "tick_size": 11,
    "label_size": 12,
    "title_size": 13
  },
  "frame": {
    "color": "#000000",
    "width": 0.8,
    "tick_length": 3.5,
    "tick_pad": 4
  },
  "grid": {
    "color": "#b0b0b0",
    "width": 0.5,
    "dasharray": "2,3"
  },
  "colors": {
    "tab10": [
      "#1f77b4", "#ff7f0e", "#2ca02c", "#d62728", "#9467bd",
      "#8c564b", "#e377c2", "#7f7f7f", "#bcbd22", "#17becf"
    ],
    "named": {
      "blue":   "#1f77b4",
      "orange": "#ff7f0e",
      "green":  "#2ca02c",
      "red":    "#d62728",
      "purple": "#9467bd",
      "brown":  "#8c564b",
      "pink":   "#e377c2",
      "gray":   "#7f7f7f",
      "olive":  "#bcbd22",
      "cyan":   "#17becf",
      "k": "#000000",
      "w": "#ffffff",
      "b": "#1f77b4",
      "g": "#2ca02c",
      "r": "#d62728"
    }
  },
  "linestyles": {
    "-":  null,
    "--": "6,3",
    ":":  "1,3",
    "-.": "6,3,1,3"
  },
  "defaults": {
    "linewidth": 1.5,
    "markersize": 4,
    "marker_stroke_width": 1.4,
    "scatter_s": 25,
    "scatter_alpha": 0.85,
    "fill_alpha": 0.3,
    "bar_alpha": 1,
    "hist_alpha": 1,
    "bar_padding": 0.2,
    "hist_gap": 1.0,
    "refline_color": "#000000",
    "refline_width": 0.8,
    "refspan_color": "#000000",
    "refspan_alpha": 0.2,
    "default_cmap": "viridis",
    "imshow_max_rects": 10000
  },
  "legend": {
    "row_height": 16,
    "pad_x": 8,
    "pad_y": 6,
    "swatch_width": 22,
    "background": "#ffffff",
    "opacity": 0.92,
    "border_offset": 6,
    "gradient_width": 14,
    "gradient_height": 60,
    "gradient_n_stops": 32,
    "section_gap": 8
  },
  "layout": {
    "gap": 20,
    "inner_gap": 12,
    "legend_gap": 6
  }
}
