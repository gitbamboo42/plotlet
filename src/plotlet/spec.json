{
  "version": "0.1.0",
  "size": {
    "data_width": 524,
    "data_height": 322,
    "margin_floor": {"top": 4, "right": 4, "bottom": 4, "left": 4},
    "inset_margin": {"top": 6, "right": 6, "bottom": 18, "left": 28}
  },
  "figure": {
    "background": "#fff"
  },
  "font": {
    "family": "DejaVu Sans, Bitstream Vera Sans, Verdana, Arial, sans-serif",
    "tick_size": 11,
    "label_size": 12,
    "title_size": 13,
    "color": "#000"
  },
  "pad": {
    "title": 10,
    "xlabel": 6,
    "ylabel": 6
  },
  "frame": {
    "color": "#000000",
    "width": 0.8,
    "tick_length": 3.5,
    "minor_tick_ratio": 0.55,
    "tick_pad": 4,
    "tick_direction": "out",
    "tick_top": false,
    "tick_right": false,
    "spine_top": true,
    "spine_right": true,
    "spine_bottom": true,
    "spine_left": true
  },
  "grid": {
    "color": "#b0b0b0",
    "width": 0.5,
    "dasharray": "2,3",
    "default_on": false
  },
  "colors": {
    "tab10": [
      "#1f77b4", "#ff7f0e", "#2ca02c", "#d62728", "#9467bd",
      "#8c564b", "#e377c2", "#7f7f7f", "#bcbd22", "#17becf"
    ],
    "named": {
      "blue":   "#1f77b4",
      "orange": "#ff7f0e",
      "green":  "#2ca02c",
      "red":    "#d62728",
      "purple": "#9467bd",
      "brown":  "#8c564b",
      "pink":   "#e377c2",
      "gray":   "#7f7f7f",
      "olive":  "#bcbd22",
      "cyan":   "#17becf",
      "k": "#000000",
      "w": "#ffffff",
      "b": "#1f77b4",
      "g": "#2ca02c",
      "r": "#d62728"
    }
  },
  "linestyles": {
    "-":  null,
    "--": "6,3",
    ":":  "1,3",
    "-.": "6,3,1,3"
  },
  "defaults": {
    "linewidth": 1.5,
    "markersize": 4,
    "marker_stroke_width": 1.4,
    "scatter_s": 25,
    "scatter_alpha": 0.85,
    "fill_alpha": 0.3,
    "bar_alpha": 1,
    "hist_alpha": 1,
    "category_padding": 0.2,
    "x_expand": [0.05, 0.05],
    "y_expand": [0.05, 0.05],
    "hist_gap": 1.0,
    "refline_color": "#000000",
    "refline_width": 0.8,
    "refspan_color": "#000000",
    "refspan_alpha": 0.2,
    "default_cmap": "viridis",
    "imshow_max_rects": 10000,
    "dendrogram_color": "#1a1a1a",
    "dendrogram_linewidth": 0.7,
    "text_color": "#222222",
    "text_size": 11,
    "errorbar_linewidth": 1.2,
    "errorbar_capsize": 4,
    "text_bbox": {
      "facecolor": "#ffffff",
      "edgecolor": "none",
      "pad": 3.0,
      "alpha": 0.85,
      "linewidth": 0.6
    },
    "annotate": {
      "arrow_head": 7.0,
      "arrow_width": 0.9,
      "arrow_base_ratio": 0.45
    }
  },
  "legend": {
    "row_height": 16,
    "pad_x": 8,
    "pad_y": 6,
    "swatch_width": 22,
    "background": "#ffffff",
    "opacity": 0.92,
    "border_offset": 6,
    "gradient_width": 14,
    "gradient_height": 60,
    "gradient_n_stops": 32,
    "section_gap": 8
  },
  "layout": {
    "gap": 0,
    "legend_gap": 6
  }
}
