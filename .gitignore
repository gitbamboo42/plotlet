# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Build / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl

# Virtual envs
.venv/
venv/
env/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.pyright/
.ruff_cache/

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Notebooks
.ipynb_checkpoints/

# Test gallery output (regenerated by `python tests/test_*.py --gallery`)
tests/baseline_images/*/index.html

# Test failure artifacts (regenerated on every baseline mismatch)
tests/baseline_images/**/*.actual.svg

# figure_lint report output (regenerated by `python tests/lint_report.py`)
tests/lint_report.html

# Cookbook example output (regenerated by running each recipe, or by
# `python cookbook/_gallery.py` which also writes index.html)
cookbook/**/*.svg
cookbook/index.html

# Examples gallery output (regenerated by running each recipe, or by
# `python examples/_gallery.py` which also writes index.html)
examples/*.svg
examples/index.html

# Extensions gallery output (regenerated by running each extension, or by
# `python -m plotlet.extensions._gallery` which also writes index.html)
src/plotlet/extensions/*.svg
src/plotlet/extensions/index.html

# AI assistant guidance (local-only; CLAUDE.md itself is committed)
CLAUDE.local.md
.claude/

# Personal working notes
TODO*.md

# Speculative drafts / aspirational docs — not part of the project yet
future/

marsilea*/
comut*/
complexheatmap/
code_anatomy/
density_heatmap/
oncoprint/
upset/
cookbook/circle/data
